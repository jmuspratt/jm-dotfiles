# PATH
export PATH="$HOME/bin:/usr/local/bin:$PATH"
export PATH="$HOME/.composer/vendor/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Editor
export EDITOR='code'

# oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="spaceship"
SPACESHIP_BATTERY_SHOW=false
source "$HOME/.oh-my-zsh/custom/themes/spaceship.zsh-theme"

plugins=(git)

source $ZSH/oh-my-zsh.sh

# Plugins installed via Homebrew (sourced directly)
source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# fnm — node version manager (replaces nvm, respects .nvmrc)
eval "$(fnm env --use-on-cd --shell zsh)"

# zoxide — smarter cd
eval "$(zoxide init zsh)"

# exiftool: rename media files in cwd by their EXIF timestamp
# Tags are tried in order; later tags override earlier ones, so priority is:
# DateTimeOriginal > MediaCreateDate > CreateDate
mediaName() {
  exiftool \
    '-filename<CreateDate' \
    '-filename<MediaCreateDate' \
    '-filename<DateTimeOriginal' \
    -d %Y-%m-%d-%H-%M-%S%%-c.%%le -api QuickTimeUTC=1 .
}

# exifstamp: set DateTimeOriginal from filename (expects YYYY-MM-DD prefix)
exifstamp() {
  exiftool '-datetimeoriginal<${filename} 00:00:00/' .
}

# Machine-specific config (gitignored) — server aliases, private tokens, etc.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
